# ── TMDB API Credentials ────────────────────────────────────
#
# The Read Access Token (JWT) is the recommended authentication method.
# It is used as a Bearer token and is NEVER sent to the browser.
#
# To get your token:
#   1. Go to https://www.themoviedb.org/settings/api
#   2. Copy the value under "API Read Access Token (v4 auth)"
#
TMDB_READ_TOKEN=YOUR_TMDB_READ_ACCESS_TOKEN_HERE
